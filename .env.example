PORT=8000
SHELL_TIMEOUT_SEC=120
MAX_REQUEST_BODY=10485760

# When set, all endpoints require this key via Authorization: Bearer <key> or X-API-Key: <key>
# Generate with: openssl rand -hex 32
API_KEY=

# n8n (for importing sub-workflows; optional)
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=your-api-key
